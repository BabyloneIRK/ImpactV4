            "liquid": "<style>\n  .underfit-ugc__track-wrap {\n    max-width: 1180px;\n    margin: 0 auto;\n    padding: 12px 16px 24px;\n  }\n\n  .underfit-ugc__track {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding: 6px 0 16px;\n    scrollbar-width: none;\n  }\n\n  .underfit-ugc__track::-webkit-scrollbar {\n    display: none;\n  }\n\n  .underfit-ugc__card {\n    flex: 0 0 240px;\n    height: 425px;\n    border-radius: 24px;\n    overflow: hidden;\n    position: relative;\n    scroll-snap-align: start;\n    cursor: pointer;\n    background: #0f0f0f;\n    border: 1px solid rgba(255,255,255,0.12);\n    box-shadow:\n      0 18px 42px rgba(0,0,0,0.14),\n      0 0 0 1px rgba(255,255,255,0.28) inset;\n    transition: transform .35s ease, box-shadow .35s ease;\n    opacity: 0;\n    transform: translateY(14px);\n    animation: underfitUgcIn .55s ease forwards;\n  }\n\n  .underfit-ugc__card:nth-child(1) { animation-delay: .05s; }\n  .underfit-ugc__card:nth-child(2) { animation-delay: .12s; }\n  .underfit-ugc__card:nth-child(3) { animation-delay: .19s; }\n\n  @keyframes underfitUgcIn {\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  .underfit-ugc__card:hover {\n    transform: translateY(-5px);\n    box-shadow:\n      0 24px 58px rgba(0,0,0,0.20),\n      0 0 0 1px rgba(255,255,255,0.34) inset;\n  }\n\n  .underfit-ugc__card video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .underfit-ugc__card::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      linear-gradient(to top, rgba(0,0,0,0.74) 0%, rgba(0,0,0,0.24) 40%, rgba(0,0,0,0.02) 70%),\n      linear-gradient(to bottom, rgba(255,255,255,0.10), transparent 30%);\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  .underfit-ugc__overlay {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    padding: 17px 15px;\n    pointer-events: none;\n    z-index: 2;\n  }\n\n  .underfit-ugc__pill {\n    display: inline-flex;\n    align-self: flex-start;\n    background: rgba(255,255,255,0.92);\n    color: #111;\n    border: 1px solid rgba(255,255,255,0.18);\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif;\n    font-size: 8px;\n    font-weight: 800;\n    letter-spacing: 1.25px;\n    text-transform: uppercase;\n    padding: 6px 10px;\n    border-radius: 999px;\n    margin-bottom: 10px;\n    box-shadow: 0 8px 18px rgba(0,0,0,0.18);\n  }\n\n  .underfit-ugc__hook {\n    color: #fff;\n    font-family: -apple-system, BlinkMacSystemFont, \"Helvetica Neue\", Arial, sans-serif;\n    font-size: 16px;\n    font-weight: 500;\n    line-height: 1.28;\n    letter-spacing: -0.35px;\n    text-shadow: 0 2px 14px rgba(0,0,0,0.48);\n  }\n\n  .underfit-ugc__hook em {\n    font-style: normal;\n    font-weight: 700;\n    color: #ffffff;\n  }\n\n  @media (max-width: 768px) {\n    .underfit-ugc__card {\n      flex: 0 0 210px;\n      height: 374px;\n      border-radius: 22px;\n    }\n\n    .underfit-ugc__track {\n      gap: 14px;\n    }\n\n    .underfit-ugc__hook {\n      font-size: 14.5px;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .underfit-ugc__track-wrap {\n      padding: 8px 12px 20px;\n    }\n\n    .underfit-ugc__card {\n      flex: 0 0 172px;\n      height: 306px;\n      border-radius: 20px;\n    }\n\n    .underfit-ugc__overlay {\n      padding: 13px 11px;\n    }\n\n    .underfit-ugc__pill {\n      font-size: 7px;\n      letter-spacing: 0.9px;\n      padding: 5px 8px;\n      margin-bottom: 8px;\n    }\n\n    .underfit-ugc__hook {\n      font-size: 12.5px;\n      line-height: 1.25;\n    }\n  }\n\n  @media (max-width: 360px) {\n    .underfit-ugc__card {\n      flex: 0 0 160px;\n      height: 284px;\n    }\n\n    .underfit-ugc__hook {\n      font-size: 12px;\n    }\n  }\n\n  @media (prefer