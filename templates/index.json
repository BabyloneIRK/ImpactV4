    "faq_9PcTWt": {
      "type": "faq",
      "blocks": {
        "item_BxWWYb": {
          "type": "item",
          "settings": {
            "title": "Who is CoreArmour™ designed for?",
            "content": "<p>CoreArmour™ is built for men looking to slim down their appearance, regain body confidence, straighten their posture, feel more energized throughout the day, and look leaner under any outfit.</p>"
          }
        },
        "item_i4a3ng": {
          "type": "item",
          "settings": {
            "title": "How does the CoreArmour™ tank actually work?",
            "content": "<p>CoreArmour™ uses advanced Ionic Compression fabric engineered to activate your body's natural response. Its micro-weave fibers promote healthy blood flow and help you maintain an upright, alert posture from morning to night. With consistent wear, it delivers a visibly streamlined torso, better spinal alignment, and an overall boost in how you look and feel.</p>"
          }
        },
        "item_j6zawx": {
          "type": "item",
          "settings": {
            "title": "How quickly will I notice results?",
            "content": "<p>Every body is different, but the majority of customers report a visible transformation within the first 30 days. For maximum impact, wear your CoreArmour™ daily and complement it with balanced nutrition and regular movement.</p>"
          }
        },
        "item_FJwr4n": {
          "type": "item",
          "settings": {
            "title": "What happens if my size doesn't fit?",
            "content": "<p>Not a problem at all. Simply contact us at contact@core-armour.com and our team will arrange an exchange right away.</p>"
          }
        }
      },
